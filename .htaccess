Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(app|database|storage)(/|$) - [F,L]
    RewriteRule ^$ public/ [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

<FilesMatch "(\.env|\.env\.example|composer\.(json|lock)|README\.md)$">
    Require all denied
</FilesMatch>
