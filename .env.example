APP_NAME="Dashboard Base"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/ccopaeca
APP_TIMEZONE=America/Lima
APP_SESSION_NAME=base_dashboard_session
APP_SECURE_COOKIES=false

API_PERU_TOKEN=
API_PERU_BASE_URL=https://apiperu.dev/api
API_PERU_SSL_VERIFY=true

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dashboard_base
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Clave para cifrar contrasenas de cuentas de correo (base64, 32 bytes).
# CRITICO: si esta clave cambia, las contrasenas SMTP ya guardadas en la
# base de datos (tabla mail_accounts) dejan de poder descifrarse.
# Generar nueva: php -r "echo base64_encode(random_bytes(SODIUM_CRYPTO_SECRETBOX_KEYBYTES));"
MAIL_ENCRYPTION_KEY=

# Cuenta que envia las notificaciones del formulario de contacto del landing.
# El destinatario real se configura en Configuracion > Correo de soporte.
MAIL_NOTIFY_HOST=
MAIL_NOTIFY_PORT=465
MAIL_NOTIFY_EMAIL=
MAIL_NOTIFY_PASSWORD=
