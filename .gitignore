# Environment and secrets
.env
.env.*
!.env.example

# Dependencies
/vendor/
/node_modules/

# Runtime storage
/storage/logs/*.log
/storage/purifier/
/storage/mail_attachments/
/storage/uploads/*
!/storage/uploads/.htaccess
!/storage/**/.gitkeep

# Public uploads generated by the app
/public/uploads/media/*
/public/uploads/posts/*
/public/uploads/settings/*
/public/uploads/vouchers/*
!/public/uploads/**/.gitkeep

# Local tool/cache folders
/.codex/
/.claude/
/.tmp_sessions/
sess_*

# OS/editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/

# Archives and local deployment bundles
*.zip
*.tar
*.tar.gz
*.rar
